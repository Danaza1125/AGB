@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Aparna Gold Buyers - Login</title>
    <link href="~/Content/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            background: radial-gradient(circle at top, #2c2c2c 0%, #1a1a1a 100%);
            font-family: 'Segoe UI', sans-serif;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            color: #fff;
            margin: 0;
        }

        .login-card {
            background: #121212;
            border: 1px solid rgba(212, 175, 55, 0.4);
            border-radius: 16px;
            box-shadow: 0 0 25px rgba(191, 161, 74, 0.25);
            padding: 50px 40px;
            width: 400px;
            text-align: center;
            animation: fadeIn 0.8s ease-in-out;
        }

        .login-logo {
            width: 100px;
            height: auto;
            margin-bottom: 20px;
            user-select: none;
        }

        .login-title {
            color: #d4af37;
            font-weight: 600;
            margin-bottom: 25px;
            letter-spacing: 1px;
            font-size: 1.6rem;
        }

        .form-control {
            background: #1f1f1f;
            border: 1px solid #bfa14a;
            color: #fff;
            border-radius: 6px;
            height: 45px;
        }

        .form-control:focus {
            border-color: #d4af37;
            box-shadow: 0 0 8px #d4af37;
        }

        .btn-gold {
            background: linear-gradient(135deg, #d4af37, #b8860b);
            border: none;
            color: #000;
            font-weight: 600;
            width: 100%;
            border-radius: 6px;
            height: 45px;
            transition: 0.3s ease-in-out;
            position: relative;
            overflow: hidden;
        }

        .btn-gold:hover {
            background: linear-gradient(135deg, #ffd700, #c4a300);
            color: #000;
            box-shadow: 0 0 15px rgba(212, 175, 55, 0.6);
        }

        .footer-text {
            margin-top: 25px;
            font-size: 13px;
            color: #aaa;
        }

        #message {
            margin-bottom: 15px;
            font-size: 14px;
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(-15px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
    </style>
</head>

<body>
    <div class="login-card">
        <img src="/Images/Aparnalogonew.png" alt="Aparna Gold Buyers" class="login-logo" />
        <h2 class="login-title">Aparna Gold Buyers</h2>

        <div id="message"></div>

        <form id="loginForm">
            <div class="form-group mb-3">
                <input type="text" id="Username" name="Username" class="form-control" placeholder="Username" required />
            </div>
            <div class="form-group mb-4">
                <input type="password" id="Password" name="Password" class="form-control" placeholder="Password" required />
            </div>
            <button type="submit" class="btn btn-gold">Login</button>
        </form>

        <div class="footer-text">© 2025 Aparna Gold Buyers. All rights reserved.</div>
    </div>

    <script src="~/Scripts/jquery-3.4.1.min.js"></script>
    <script src="~/Scripts/bootstrap.min.js"></script>
    <script src="~/Scripts/login/login.js"></script>
</body>
</html>
